<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SliceStation</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="icon" type="image/png" href="~/slice_station_logo.png" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <!-- Precarica il font per evitare FOUT (Flash Of Unstyled Text) -->
    <link rel="preload" 
          href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;1,400;1,500&display=block" 
          as="style" 
          onload="this.onload=null;this.rel='stylesheet'">
    <noscript>
        <link href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;1,400;1,500&display=block" rel="stylesheet">
    </noscript>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
</head>
<body>
    <style>
        nav{
            background: rgba(0,0,0,0.8) !important; 
            position: fixed !important;
            top: 0;
            width: 100%;
            left: 0;
            z-index: 100;
            display: flex !important;
            flex-direction: row !important;
            justify-content: space-between !important;
            transition: 1.3s ease-in-out;
        }

        nav:hover{
            background: rgba(0,0,0,0.9) !important;
        }


        .nav-link, .navbar-brand{
            color: rgba(255,255,255,0.6) !important;
        }

        .nav-link:hover, .navbar-brand:hover {
            color: rgba(255,255,255,1) !important;
        }

        .img-logo{
            width: 200px;
            height: auto;
            object-fit: cover;
            transform: scale(1);
            transition: 0.8s ease-in-out;
        }

        .img-logo:hover {
            transform: scale(1.03);
            transition: 0.8s ease-in-out;
            border-radius: 15px;
            background: rgba(255,255,255, 0.7);
        }

    </style>


    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm box-shadow">
            <div class="container">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index"><img rel="icon" type="image/png" src="~/slice_station_logo.png" class="img-logo"/></a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Pizza" asp-action="Menu">Menu</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Pizza" asp-action="Cart">Cart</a>
                        </li>
                        <partial name="_AccountPartial" class="acc-par"/>
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container2">
        <main>
            @RenderBody()
        </main>
    </div>

    

    
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
