@{
    ViewData["Title"] = "Home page";
}

<style>
    html, body{
        margin: 0;
        padding: 0;
        box-sizing: border-box;
        z-index: -5;
        background: rgba(0,0,0,0.7);
    }

    h1, h2 {
        font-family: 'Lora', sans-serif;
    }
    
    body, p {
        font-family: 'Lato', sans-serif;
    }
    

    body, html, main{
        width: 100% !important;
    }

    .slides {
        position: relative;
        width: 100%;
        height: 100%;
        display: flex;
        flex-direction: row;
        object-fit: cover;
    }

    .slide {
        z-index: -1;
        display: none;
        width: 100%;
        height: 120vh;  /* Aumenta altezza per compensare il movimento */
        object-fit: cover;
        object-position: center top;  /* Allinea in alto */
        will-change: transform;  /* Ottimizzazione performance */
    }

    .slider {
        width: 100%;
        height: 100vh;
        display: flex;
        flex-direction: row;
        overflow: hidden;  /* Nasconde tutto l'overflow */
    }

    .slide.active{
        display: block;
        object-fit:cover;
    }

    body{
        position: relative;
    }

    .infos{
        z-index: 1;
        position: absolute;
        right: 50%;
        transform: translateX(50%) ;
        top: 45%;
        width: auto;  /* Larghezza automatica basata sul contenuto */
        height: 200px;
        pading: 20px 30px 20px 30px;
        display: flex;
        flex-direction: column; 
        align-items: center; 
        justify-content: center;
        gap: 20px;
        color: white;
        text-shadow: 10px 10px 15px rgba(0,0,0,0.8);
        animation: tit-an 1.5s ease-in-out forwards;
    }

    .infos > h2{
        font-size: 200px;
        white-space: nowrap;  /* Non va mai a capo */
    }

    .infos > h3 {
        font-size: 40px;
    }

    @@media(max-width: 1500px){
        .infos > h2 {
            font-size: 150px;
        }

        .infos > h3 {
            font-size: 25px;
        }
    }

    @@keyframes tit-an{
        0%{
            opacity: 0.4;
            transform: translateY(250px) translateX(50%);
        }
        

        100% {
            opacity: 1;
            transform: translateY(0px) translateX(50%);
        }
    }

    .main-container{
        margin-top: 100px;
        width: 100%;
        height: auto;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: flex-start;
        padding-bottom: 100px;
    }

    .chi-siamo{
        width: 80%;
        display: flex; 
        flex-direction: row;
        justify-content: space-between;
        color: rgba(255,255,255, 0.8);
        overflow: hidden; 
    }

    .cont-par{
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        justify-content: center;
        width: 50%;
    }

    .cont-par > h1{
        margin-bottom: 25px;
    }

    .cont-par > h4{
        line-height: 1.7;
    }

    .f-pizzeria{
        width: 40%;
        height: auto;
        transition: transform 0.1s ease-out;  /* Transizione fluida */
        will-change: transform;  /* Ottimizzazione performance */
    }

    .img-obs{
        visibility: hidden;
    }

    .img-obs:nth-child(1).visible{
        animation: img-anim 3s forwards;
    }

    .img-obs:nth-child(2).visible {
        animation: img-anim2 3s forwards;
    }

    @@keyframes img-anim{
        0%{
            opacity: 0.4;
            transform: translateX(-350px);

        }

        100% {
            visibility: visible;
            opacity: 1;
            transform: translateX(0px);
        }

    }

    @@keyframes img-anim2 {
        0% {
            opacity: 0.4;
            transform: translateX(350px);
        }

        100% {
            visibility: visible;
            opacity: 1;
            transform: translateX(0px);
        }
    }


    .par-obs{
        visibility: hidden;
    }

    .par-obs.visible{
        animation: par-anim 3s forwards;
    }

    @@keyframes par-anim {
        0% {
            opacity: 0.4;
        }

        100% {
            visibility: visible;
            opacity: 1;
        }
    }

    .nostri-servizi{
        margin-top: 120px;
        width: 100%;
        display: flex;
        flex-direction: row;
        justify-content: center;  /* Centra il contenuto */
        background: rgba(0,0,0,0.2);
        padding: 20px 0px;
    }

    .freccia-g{
        display: inline-block;  /* Necessario per transform su span */
        animation: ar 3s infinite;
    }

    @@keyframes ar{
        0%{
            transform: translateY(10px)
        }

        50% {
            transform: translateY(-10px)
        }

        100% {
            transform: translateY(10px)
        }
    }


   
</style>

<div class="slider">
    <div class="slides">
        <img class="slide"  src="~/src/foto_slider/foto2.jpg" />
        <img class="slide" src="~/src/foto_slider/foto1.jpg" />
        <img class="slide"  src="~/src/foto_slider/foto3.jpg" />
        <div class="infos">
            <h2>Slice Station</h2>
            <h3><span class="freccia-g">↓</span> Scroll Down <span class="freccia-g">↓</span></h3>
        </div>

        
    </div>
</div>

<div class="main-container">
    <div class="chi-siamo">
        <img src="~/src/pizzeria_orizzontale.jpg" class="f-pizzeria img-obs"/>
        <div class="cont-par par-obs">
            <h1>About Us</h1>
            <h4><strong>Slice Station</strong> was born in 2016 from a simple idea: bring <strong>real pizza</strong> — the kind with 24-hour risen dough and ingredients picked fresh from the market every day — into a casual, welcoming space. What started as a small wood-fired oven at Via dei Mille 14, Bologna, has since grown into a go-to spot for anyone craving <strong>artisanal pizza</strong> without giving up the pace of a quick night out with friends. The same passion from that first batch still guides every slice that comes out of our oven.</h4>
        </div>
    </div>

    <div class="nostri-servizi">
        <div class="chi-siamo">
            
            <div class="cont-par par-obs">
                <h1>About Us</h1>
                <h4><strong>Slice Station</strong> was born in 2016 from a simple idea: bring <strong>real pizza</strong> — the kind with 24-hour risen dough and ingredients picked fresh from the market every day — into a casual, welcoming space. What started as a small wood-fired oven at Via dei Mille 14, Bologna, has since grown into a go-to spot for anyone craving <strong>artisanal pizza</strong> without giving up the pace of a quick night out with friends. The same passion from that first batch still guides every slice that comes out of our oven.</h4>
            </div>
            <img src="~/src/pizzeria_orizzontale.jpg" class="f-pizzeria img-obs" />
        </div>
    </div>
</div>

@section Scripts{
    <script src="~/js/Slider.js"></script>
}