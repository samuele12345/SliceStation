@{
    ViewData["Title"] = "Home page";
}

<style>
    html, body{
        margin: 0;
        padding: 0;
        box-sizing: border-box;
        z-index: -5;
        background: rgba(0,0,0,0.7);
    }

    h1, h2 {
        font-family: 'Lora', sans-serif;
    }
    
    body, p {
        font-family: 'Lora', sans-serif;
    }
    

    body, html, main{
        width: 100% !important;
    }

    .slides {
        position: relative;
        width: 100%;
        height: 100%;
        display: flex;
        flex-direction: row;
        object-fit: cover;
    }

    .slide {
        z-index: -1;
        display: none;
        width: 100%;
        height: 120vh;  /* Aumenta altezza per compensare il movimento */
        object-fit: cover;
        object-position: center top;  /* Allinea in alto */
        will-change: transform;  /* Ottimizzazione performance */
    }

    .slider {
        width: 100%;
        height: 100vh;
        display: flex;
        flex-direction: row;
        overflow: hidden;  /* Nasconde tutto l'overflow */
    }

    .slide.active{
        display: block;
        object-fit:cover;
    }

    body{
        position: relative;
    }

    .infos{
        z-index: 1;
        position: absolute;
        left: 50%;
        top: 45%;
        transform: translateX(-50%) translateZ(0);  /* translateZ forza GPU */
        width: auto;
        height: 200px;
        display: flex;
        flex-direction: column; 
        align-items: center; 
        justify-content: center;
        gap: 20px;
        color: white;
        text-shadow: 10px 10px 15px rgba(0,0,0,0.8);
        animation: tit-an 1.5s ease-in-out both;
        backface-visibility: hidden;  /* Previene flickering */
        will-change: transform, opacity;
        color: #f5f5dc;
    }

    .infos > h2{
        font-size: 200px;
        white-space: nowrap;  /* Non va mai a capo */
    }

    .infos > h3 {
        font-size: 40px;
    }

    @@media(max-width: 1600px){
        .infos > h2 {
            font-size: 130px;
        }

        .infos > h3 {
            font-size: 25px;
        }

        .cont-par > h1 {
            margin-bottom: 20px;
            font-size: 25px;
        }


        .cont-par > h4 {
            line-height: 1.7;
            font-size: 20px;
        }
    }

    @@keyframes tit-an{
        0%{
            opacity: 0.4;
            transform: translateY(250px) translateX(-50%) translateZ(0);
        }


        100% {
            opacity: 1;
            transform: translateY(0px) translateX(-50%) translateZ(0);
        }
    }

    .main-container{
        margin-top: 150px;
        width: 100%;
        height: auto;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: flex-start;
        padding-bottom: 100px;
    }

    .chi-siamo{
        width: 80%;
        display: flex; 
        flex-direction: row;
        justify-content: space-between;
        color: rgba(255,255,255, 0.8);
        overflow: hidden; 
    }

    .chi-siamo {
        width: 80%;
        display: flex;
        flex-direction: row;
        justify-content: space-between;
        color: rgba(255,255,255, 0.8);
        overflow: hidden;
    }

    .location {
        margin-top: 170px;
        width: 80%;
        display: flex;
        flex-direction: row;
        justify-content: space-between;
        color: rgba(255,255,255, 0.8);
        overflow: hidden;
    }

    .map-dark {
        filter: invert(90%) hue-rotate(180deg) brightness(95%) contrast(90%);
    }

    .cont-par{
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        justify-content: center;
        width: 50%;
    }

    .cont-par > h1{
        margin-bottom: 25px;
    }

    .cont-par > h4{
        line-height: 1.7;
    }

    .f-pizzeria{
        width: 40%;
        height: auto;
        transition: transform 0.1s ease-out;  /* Transizione fluida */
        will-change: transform;  /* Ottimizzazione performance */

    }

    .slider-piz{
        position: relative;
        width: 40%;
        height: auto;
        transition: transform 0.1s ease-out; /* Transizione fluida */
        will-change: transform; /* Ottimizzazione performance */
        display: flex;
        flex-direction: row;
        align-items: center;
        justify-content: left;
    }

    .slide-piz{
        width: 100%;  
        aspect-ratio: 3 / 2; /* Forza proporzioni 16:9 - tutte le immagini avranno la stessa altezza */
        display: none;  
        object-fit: cover;  
        height: auto;
    }

    .slide-piz.active {
        display: block;
        object-fit: cover;
    }

    .img-obs, .img-obs2{
        visibility: hidden;
    }

    .img-obs.visible{
        animation: img-anim 3s forwards;
    }

    .img-obs2.visible {
        animation: img-anim2 3s forwards;
    }

    @@keyframes img-anim{
        0%{
            opacity: 0.4;
            transform: translateX(-350px);

        }

        100% {
            visibility: visible;
            opacity: 1;
            transform: translateX(0px);
        }

    }

    @@keyframes img-anim2 {
        0% {
            opacity: 0.4;
            transform: translateX(350px);
        }

        100% {
            visibility: visible;
            opacity: 1;
            transform: translateX(0px);
        }
    }


    .par-obs{
        visibility: hidden;
    }

    .par-obs.visible{
        animation: par-anim 3s forwards;
    }

    @@keyframes par-anim {
        0% {
            opacity: 0.4;
        }

        100% {
            visibility: visible;
            opacity: 1;
        }
    }

    .nostri-servizi{
        margin-top: 170px;
        width: 100%;
        display: flex;
        flex-direction: row;
        justify-content: center;  /* Centra il contenuto */
        background: rgba(0,0,0,0.2);
        padding: 20px 0px;
    }

    .freccia-g{
        display: inline-block;  /* Necessario per transform su span */
        animation: ar 3s infinite;
    }

    @@keyframes ar{
        0%{
            transform: translateY(10px)
        }

        50% {
            transform: translateY(-10px)
        }

        100% {
            transform: translateY(10px)
        }
    }

    #link-home{
        width: 100%;
        display: flex;
        flex-direction: row;
        justify-content: center;
    }
    
    .link-menu {
        border-bottom: 1px solid transparent;
        color: white;
        text-decoration: none;
    }

    .link-menu:hover {
        border-bottom: 1px solid white;
    }
</style>

<div class="slider">
    <div class="slides">
        <img class="slide"  src="~/src/foto_slider/foto2.jpg" />
        <img class="slide" src="~/src/foto_slider/foto1.jpg" />
        <img class="slide"  src="~/src/foto_slider/foto3.jpg" />
        <div class="infos">
            <h2>Slice Station</h2>
            <h3><span class="freccia-g">↓</span> Scroll Down <span class="freccia-g">↓</span></h3>
        </div>

        
    </div>
</div>

<div class="main-container">
    <div class="chi-siamo">
        <img src="~/src/pizzeria_orizzontale.jpg" class="f-pizzeria img-obs"/>
        <div class="cont-par par-obs">
            <h1>About Us</h1>
            <h4><strong>Slice Station</strong> was born in 2016 from a simple idea: bring <strong>real pizza</strong> — the kind with 24-hour risen dough and ingredients picked fresh from the market every day — into a casual, welcoming space. What started as a small wood-fired oven at Via dei Mille 14, Bologna, has since grown into a go-to spot for anyone craving <strong>artisanal pizza</strong> without giving up the pace of a quick night out with friends. The same passion from that first batch still guides every slice that comes out of our oven.</h4>
        </div>
    </div>

    <div class="nostri-servizi">
        <div class="chi-siamo">
            
            <div class="cont-par par-obs">
                <h1>Our Products</h1>
                <h4>Every pizza at Slice Station is <strong>crafted to surprise</strong>, without ever straying from tradition. From the autumn sweetness of pumpkin paired with crispy pancetta, to the lightness of our whole wheat oval-shaped pizza, all the way to the rich embrace of dark and milk chocolate for those who love to end on a sweet note: three different ways to reinvent pizza, one for every craving. Explore our <a class="link-menu" asp-controller="Pizza" asp-action="Menu">Menu</a>.</h4>
                
            </div>
            <div class="slider-piz">
                <div class="slides-piz img-obs2">

                    <img src="~/src/pizza-zucca.jpg" class="slide-piz" />
                    <img src="~/src/pizza-ovale.jpg" class="slide-piz" />
                    <img src="~/src/pizza-dolce.jpg" class="slide-piz" />
                </div>
            </div>
        </div>
    </div>

    <div class="location">
        <!-- Mappa con modalità scura -->
        <iframe 
            class="map-dark"
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d13312.765054544521!2d9.174672541800469!3d45.45642448190458!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x4786c6aec34636a1%3A0xab7f4e27101a2e13!2sDuomo%20di%20Milano!5e0!3m2!1sit!2sit!4v1783525104911!5m2!1sit!2sit" 
            width="40%" 
            height="auto" 
            style="border:0;" 
            allowfullscreen="" 
            loading="lazy" 
            referrerpolicy="strict-origin-when-cross-origin">
        </iframe>
        
        <div class="cont-par par-obs">
            <h1>Find Us</h1>
            <h4>Tucked along <strong>Via dei Mille 14</strong>, in the heart of Bologna, Slice Station is easy to reach whether you're strolling through the city or looking for the perfect spot to end your day. We're open Tuesday to Sunday, from 12:00 to 15:00 and 7:00 PM to 11:00 PM — closed on Mondays. Whether it's a quick lunch or a relaxed dinner with friends, come find us and grab a table.</h4>
        </div>
    </div>
</div>

@section Scripts{
    <script src="~/js/Slider.js"></script>
}