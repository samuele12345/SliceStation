@{
    ViewData["Title"] = "Home page";
}

<style>
    html, body{
        margin: 0;
        padding: 0;
        box-sizing: border-box;
        font-family: "Lato";
        z-index: -5;
        background: rgba(0,0,0,0.7);
    }

    body, html, main{
        width: 100% !important;
    }
    .slides {
        position: relative;
        width: 100%;
        height: 100%;
        display: flex;
        flex-direction: row;
        object-fit: cover;
    }

    .slide {
        z-index: -1;
        display: none;
        width: 100%;
        height:100vh;
        object-fit: cover;
    }

    .slider {
        width: 100%;
        height: 100vh;
        display: flex;
        flex-direction: row;
        overflow-x: hidden;
    }

    .slide.active{
        display: block;
        object-fit:cover;
    }

    body{
        position: relative;
    }

    .infos{
        z-index: 1;
        position: absolute;
        right: 50%;
        transform: translateX(50%) ;
        top: 40%;
        width: 300px;
        height: 200px;
        pading: 20px 30px 20px 30px;
        display: flex;
        flex-direction: column; 
        align-items: center; 
        justify-content: center;
        gap: 20px;
        color: white;
        text-shadow: 10px 10px 15px rgba(0,0,0,0.8);
        animation: tit-an 1.5s ease-in-out forwards;
    }

    .infos > h2{
        font-size: 200px;

    }

    .infos > h3 {
        font-size: 40px;
    }

    @@media(max-width: 1500px){
        .infos > h2 {
            font-size: 150px;
        }

        .infos > h3 {
            font-size: 25px;
        }
    }

    @@keyframes tit-an{
        0%{
            opacity: 0.4;
            transform: translateY(250px) translateX(50%);
        }
        

        100% {
            opacity: 1;
            transform: translateY(0px) translateX(50%);
        }
    }

    .main-container{
        margin-top: 80px;
        width: 100%;
        height: auto;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: flex-start;
        padding-bottom: 100px;
    }

    .chi-siamo{
        width: 80%;
        display: flex; 
        flex-direction: row;
        justify-content: space-between;
        color: rgba(255,255,255, 0.8);
    }

    .cont-par{
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        justify-content: center;
        width: 50%;
    }

    .cont-par > h1{
        margin-bottom: 25px;
    }

    .cont-par > h4{
        line-height: 1.7;
    }

    .f-pizzeria{
        width: 40%;
        height: auto;
    }
    
</style>

<div class="slider">
    <div class="slides">
        <img class="slide"  src="~/src/foto_slider/foto2.jpg" />
        <img class="slide" src="~/src/foto_slider/foto1.jpg" />
        <img class="slide"  src="~/src/foto_slider/foto3.jpg" />
        <div class="infos">
            <h2>SliceStation</h2>
            <h3><span>↓</span> Scroll Down <span>↓</span></h3>
        </div>

        
    </div>
</div>

<div class="main-container">
    <div class="chi-siamo">
        <img src="~/src/pizzeria_orizzontale.jpg" class="f-pizzeria"/>
        <div class="cont-par">
            <h1>Chi Siamo</h1>
            <h4>Slice Station nasce nel 2016 da un'idea semplice: portare la pizza vera, quella con l'impasto lievitato 24 ore e gli ingredienti scelti ogni giorno al mercato, in un ambiente informale e accogliente. Quello che era partito come un piccolo forno a legna in Via dei Mille 14, a Bologna, oggi è diventato un punto di riferimento per chi cerca una pizza artigianale senza rinunciare alla velocità di una serata tra amici. La stessa passione della prima infornata guida ancora ogni fetta che esce dal nostro forno.</h4>
        </div>
    </div>
</div>

@section Scripts{
    <script src="~/js/Slider.js"></script>
}