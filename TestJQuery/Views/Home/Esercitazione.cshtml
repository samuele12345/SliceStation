@{
    ViewData["Title"] = "Esercitazione";
}

<div class="text-center d-flex align-items-center flex-column">
    <h1 id="tit">Titolo principale</h1>

    <div class="text-center div1">
        <p>Testo evento</p>
        <button id="but-tit">Premi</button>
        <input type="text" id="inp1">
        <p id="text-change">base</p>
    </div>

    <!--esempio di accordion, tiolo che fa a prire o chiudere un paragrafo al click, in questo caso non è necessario usare jquery ma solo css-->
    <div class="text-center div2">
        <h2 id="tit-accord">Accordion</h2>
        <p id="par-accord">Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed diam nonnumy eiusmod tempor incidunt ut labore et dolore magna aliquam erat voluptat. Ut enim ad minim veniam, quis nostrud exercitation ullamcorpor suscipit laborios nisi ut aliquip ex ea commodo consequat. Duis autem vel eum irure reprehenderit in voluptate velit esse nihil molestiae consequat, vel illum dolore eu fugiat nulla pariatur. At vero eos et accusam et iusto odio dignissim ducim qui blandit praesent luptatum delenit atgue duos dolor et molestias exceptur sint occaecat cupiditat non provident, simil sunt in culpa qui officia deserunt mollit anim id est laborum et dolor fuga. Et harumd dererud facilis est er expedit distinct. Nam liber tempor cum soluta</p>
    </div>

    <div class="w-100 cont">
        <div id="div-quad"></div>
    </div>

    
    <button id="but-start" class="mt-3">start</button>
    <button id="but-stop" class="mt-3 mb-3">skip</button>

    <h3>Inserire normale o grassetto</h3>
    <input type="text" id="inp2">
    <p id="par-prova">Testo di prova</p>


    <h3 id="tit-sito"> <a id="link-sito" href="https://www.google.com" target="_blank">Link a google</a></h3>
    <button id="but-link">Cambia link</button>

    <div id="main-img-p">
        <h3 class="mt-4 mb-3">Immagine-Paragrafo</h3>
        <div class="img-par">
            <img src="~/src/borgo.jpg" id="img-borgo"/>
            <div id="div-pars">
                <p id="par">Descrizione centrale immagine</p>
            </div>
        </div>
        <input type="text" id="inp3"/>
        <div id="div-but-p-d">
            <button id="bt-agg-prima">Testo prima paragrafo</button>
            <button id="bt-agg-dopo">Testo dopo paragrafo</button>
        </div>

        <div id="div-but-p-d">
            <button id="bt-agg-prima-div">Testo prima contenitore</button>
            <button id="bt-agg-dopo-div">Testo dopo contenitore</button>
        </div>

        <button id="clear">Pulisci</button>
        
    </div>


    <p class="mt-4 mb-2 p-err">Testo Errore</p>
    <p id="p-col">Colore: </p>

    <button id="but-err">Clicca</button>

    <div class="div-li mt-3 mb-2">
        <ul class="u-list">
            <li class="li-prim">Primo</li>
            <li class="li-prim prova">Secondo</li>
        </ul>

        <ol class="o-list">
            <li class="li-sec">Terzo</li>
        </ol>
    </div>

    <button class="but-li">Premi</button>


    <h1 class="mt-4 mb-3 tit-file">Testo dal file:</h1>
    <p class="p-file mb-3">Text: </p>
    <button class="but-file">Carica contenuto file</button>
</div>

<style>
    .errore{
        color: red;
        font-weight: 700;
    }


    #div-but-p-d{
        display: flex;
        flex-direction: row;
        gap: 10px;
        align-items: center;
        justify-content: center;
    }

    #main-img-p{
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 15px;
        margin-top: 20px;
    }

    #div-pars{
        border: 1px solid black;
        display:flex;
        flex-direction:column;
        align-items: flex-start;
        justify-content: center;
    }

    .img-par{
        display:flex;
        flex-direction: row;
        align-items:center;
        justify-content: center;
        gap:30px;
        width:100%;
    }

    #img-borgo{
        width:400px;
        height: auto;
    }

    but-start {
        margin-top: 20px;
    }

    #tit {
        display: visible;
    }

    #tit.hidden {
        display: none;
    }

    #tit-accord:hover {
        cursor: pointer;
        color: blue;
    }

    #par-accord {
        display: hidden;
    }

    #div-quad {
        height: 200px;
        width: 200px;
        border: 1px solid black;
        position: absolute;
    }

    .cont {
        position: relative;
        height: 200px;
    }

</style>



<script>
    $(document).ready(function(){

        let anim = false;
        const btit = $("#but-link");
        const lin = $("#link-sito");
        const pr = $("#div-pars");
        const tAgg = $("#inp3");
        const aggPrima = $("#bt-agg-prima");
        const aggDopo = $("#bt-agg-dopo");
        const imgPar = $(".img-par");
        const aggPrimaDiv = $("#bt-agg-prima-div");
        const aggDopoDiv = $("#bt-agg-dopo-div");
        const cl = $("#clear"); 
        const pErr = $(".p-err");
        const bErr = $("#but-err");
        const pCol = $("#p-col");
        const dLi = $(".div-li");
        const uL = $(".u-list");
        const oL = $(".o-list");
        const lP = $(".li-prim");
        const lS = $(".li-sec");
        const bLi = $(".but-li");
        const tFile = $(".tit-file");
        const pFile = $(".p-file");
        const bFile = $(".but-file");

        // prima alternativa, più adatta a singoli tasti, uno per mostrare e l'altro per nascondre, in questo caso meglio usare toggle
        /*
        $("button").click(function(){
            if($("#tit").is(":visible")){
                $("#tit").hide();
            }else{
                $("#tit").show();
            }
        });
        */

       // toggle condensa hide e show
        $("#but-tit").click(function(){
            //$("#tit").toggle(2000); // ci mette 2 secondi ad apparire o scomparire, in questo caso si muove da sinistra a destra e viceversa
            // alternative: slideToggle, fadetoggle
            //$("#tit").toggleClass("hidden"); // in questo caso usa css

            //$("#tit").fadeToggle(2000); // comprende fadeIn e fadeOut, dissolvenza
            //$("#tit").fadeTo(2000, 0.5); // per eseguire un fade in 2 secondi dello m0.5 dell'opacità

            $("#tit").slideToggle(2000);  // comprende slideUp e slideDown, scorrimento verso l'altp o verso il basso (migliore)
        });



        //keypress nel caso in cui pre,ma un qualsiasi tasto
        // keydown quando tengo premuto un tasto
        // keyup quando rilascio un tasto
        // on load quando un documento ha caricato ma non è pronto

        //hover
        $(".div1").mouseenter(function(){
            $(this).css("background-color", "rgba(0, 100, 255, 0.1)");
        })

        $(".div1").mouseleave(function(){
            $(this).css("background-color", "transparent");
        })


        /*
        // se sono focussato in nquesto caso su un campo input
        $("input").focus(function(){
            $("#text-change").text("sei nel campo");
        });

        // se esco dal campo
        $("input").blur(function(){
            $("#text-change").text("non sei nel campo");
        });

        // se cambio il valore del campo
        $("input").change(function(){
            console.log("cambio");
            // in questo caso ha la precedneza sul testo blur
            $("#text-change").text("testo cambiato");
        });
        */

        // si possono riassumere gli eventi relativi ad un tag con on:
        // ncome uno switch

        $("#inp1").on({
            focus: function(){
                $("#text-change").text("sei nel campo");

            },

            blur: function(){
                $("#text-change").text("non sei nel campo");
            },

            change: function(){
                console.log("cambio");
                // in questo caso ha la precedneza sul testo blur
                $("#text-change").text("testo cambiato");
            },

            keypress: function(e){
                if(e.key == "Enter"){ // se viene premuto enter (con input selezionato) si entra nell'if
                    console.log($(this).val()); // stampa del contenuto dell'input
                    console.log($("#inp1").attr("type")); // ritorna il tipo di attributo relativo al tag selezionato, in questo caso input
                }
            },
        })

        $(this).on({
            keypress: function(e){
                if(e.key == "Enter"){
                    console.log("hai premuto enter");
                }
            }
        })

        $("#tit-accord").click(function(){
            $("#par-accord").toggle(3000);
        })

        $("#but-start").click(function(){

            if(anim == false){
                $("#div-quad").fadeIn(1000).animate(
                {
                    left: '300px',
                    width: '100px',
                    height: '100px',
                }, 2000);
                anim = true;
            }else{
                $("#div-quad").animate(
                {
                    left: '0px',
                    width: '200px',
                    height: '200px',
                }, 2000).fadeOut(1000, function(){
                    alert("Animazione terminata");
                });
                anim = false;
            }

        })

        $("#but-stop").click(function(){
            //$("#div-quad").stop(true); // in stop(interrompere animazione, saltare animazione)

            $("#div-quad").stop(false, true); // salta l'animazione in corso
        })

        $("#inp2").on({
           keypress:
                function(e){
                    if(e.key == "Enter"){
                        let val = $(this).val();
                        if(val == "normale"){
                            //$("#par-prova").css("font-weight", "400");
                            $("#par-prova").html("Testo di prova");
                        }else if(val == "grassetto"){
                            //$("#par-prova").css("font-weight", "700");
                            $("#par-prova").html("<strong>Testo di prova</strong>");
                        }
                    }
                },

            blur:
                function(){
                    $(this).val("");
                },
        })

        
        btit.click(function(){
            if(lin.text() === "Link a google"){
                lin.text("Link a youtube");
                lin.attr("href", "https://www.youtube.com")
            }else if(lin.text() === "Link a youtube"){
                lin.text("Link a google");
                lin.attr("href", "https://www.google.com");
            }
        })

        aggPrima.click(function(){
            let cont = tAgg.val();
            pr.prepend("<p> " + cont + "</p>"); // figlio interno al div precedente al paragrafo
        })

        aggDopo.click(function(){
            let cont = tAgg.val();
            pr.append("<p> " + cont + "</p>"); // figlio interno al div successivo al paragrafo
        })

        aggPrimaDiv.click(function(){
            let cont = tAgg.val();
            pr.before("<p> " + cont + "</p>"); // componente precedente al div
        })

        aggDopoDiv.click(function(){
            let cont = tAgg.val();
            pr.after("<p> " + cont + "</p>"); // componente successivo al div
        })

        cl.click(function(){
            pr.empty(); // rimuove tutti i figli del div
            // pr.remove(); // elimina il div stesso
        })

        pCol.append(pCol.css("color"))

        bErr.click(function(){
            pErr.toggleClass("errore"); // contiene addClass e RemoveClass

            let colore = pErr.hasClass("errore") ? "red" : "black";
            pCol.css("color", colore).text(colore);
            
        })

        
        let attivo = false;
        bLi.click(function(){
            if(!attivo){
                uL.children(/*".prova"*/ /*si possono inserire classi per una maggiore precisione*/).css({"border": "1px solid black", "background": "rgba(0,0,0,0.2)"});
                attivo = true;
            }else{
                uL.children().css({"border": "none", "background": "transparent"}); // prende il primo figlio , aggiungendo un altro .children prende il nipote, find(selettore), prende tutti i figli del tipo del selettore, con .first() solo il primo, invece con find(selettore).eq(n) si trova il discendente (sia figlio che nipote... che sia) di numero n, concatenare children().eq(n).children().eq(m)
                // l'inverso vale per parent() per il genitore diretto, parents() per tutti i genitori, parentsUntil() per arrivare ad un determinato livello di ascendenti
                attivo = false;
            }
        })
        
        
       // questo su riferisce al parent, quindi agisce sul genitore diretto, ovvero il div
       /*
        let attivo = false;
        bLi.click(function(){
            if(!attivo){
                uL.parent().css({"border": "1px solid black", "background": "rgba(0,0,0,0.2)"});
                attivo = true;
            }else{
                uL.parent().css({"border": "none", "background": "transparent"}); 
                attivo = false;
            }
        })
       */

      // .siblings() serve per selezionare gli altri elementi allo stesso livello
      // .next() il sibling successsivo, .nextAll() tutti i successivi, .prev() quello precedente, .prevAll() tutti i precedenti
      // .nextUntil(n) successivi fino a un certo tag, .prevUntil() pecedenti fino a un certo tag, ad esempio .prevUntil("h1")

      
      // IDEA: caricamento file e sviluppo ocr con api
      bFile.click(function(){
          // caricamento del contenuto testuale di un file
          $.get("/txt/prova.txt", function(data){
              pFile.text("Text: ");
              pFile.append(data);
          })

          /*
          $.getJSON("/json/Prova.json", function(data){ // ottiene i dati dal json e li stampa nella console
              console.log(data);
          })
          // esiste anche post ma meglio usare la sintassi ajax
          */

         // in questo modo viene eseguito get sul file prova.json e viene stampato l'oggetto contenuto nella console
         $.ajax({
             url: "/json/prova.json", 
             type: "get",
             dataType: "json",
             data: $(this).serialize(), // utile per form. S    erializza i campi di un form in una query string, es. nome=Mario&eta=20
             success: function(response){
                 console.log(response);
             },
             // jqXHR: contiene status (codice http) e risposta testuale, header, abort...
             // textStatus: esito tecnico della richiesta come "success", "error", "timeout", "parsererror"...
                 // errorThrown: messaggio errore restituito, come "Not Found" e "Internal Server Error"
             error: function(jqXHR, textStatus, errorThrown){
                 console.log(textStatus, errorThrown);
             }

             /*
                •	form HTML normale → serialize()
                •	dati strutturati → oggetto JS
                •	API JSON / backend moderno → JSON.stringify()
                •	file → FormData

            // singolo input o pochi campi, oggetto js
            data: {
                nome: $("#nome").val(),
                email: $("#email").val()
            }

            // json verso backend

            data: JSON.stringify({
                nome: $("#nome").val(),
                email: $("#email").val()
            }),
            contentType: "application/json"

            // leggere un valore singolo:
            let nome = $("#nome").val();

            // file upload / multipart, FormData($("#mioForm")[0]);
            let formData = new FormData($("#mioForm")[0]);
             */
         })
      })
    });
</script>