
@{
    ViewData["Title"] = "Success";
}

<style>
    body, html{
        margin: 0 !important;
        padding: 0 !important;
        box-sizing: border-box;
        z-index: -5;
        background: rgba(0,0,0,0.65);
        overflow-x: hidden;
    }

    .div-main{
        width: 100%;
        height: 100vh;
        flex: 1;
        background: rgba(0,0,0,0.65);
        display: flex;
        flex-direction: row;
        align-items: center;
        justify-content: center;
    }

    .div-popup{
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        width: 100%;
        height: 60%;
        gap: 1%;
        background-image: url('/src/back-succ.jpg');
        background-size: cover;
        background-position: center;
        background-repeat: no-repeat;
    }

    h1{
        color: rgba(255, 255, 255);
        font-size: 80px;
        text-shadow: 5px 5px 10px rgba(0,0,0,0.2);
    }

    h3{
        color: rgba(255, 255, 255);
        font-size: 50px;
    }

    .btn-gen {
        background: rgba(0,0,0,0.7);
        color: rgba(255, 255, 255, 0.7) !important;
        border: 1px solid rgba(255, 255, 255, 0.7) !important;
        width: 100px;
        height: 40px;
        display: flex;
        flex-direction: row;
        align-items: center;
        justify-content: center;
        margin-top: 1%;
        transition: 1s ease-in-out;
    }

    .btn-gen:hover {
        background: rgba(0,0,0);
        color: 1px solid white;
        border: white;
        transition: 1s ease-in-out;
    }
</style>

<div class="div-main">
    <div class="div-popup">
        <h1> @ViewData["Title"]</h1>
        <h3> Thank you for choosing us!</h3>
        <a class="btn btn-gen" asp-controller="Home" asp-action="Index">Home</a>
    </div>
    
</div>

@section Scripts{
    @{
        <script src=""></script>
    }
}