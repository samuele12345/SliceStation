@{
    ViewData["Title"] = "Our Menu"; 
}

<style>
    /* Rimuovi margini/padding da layout principale */
    body {
        margin: 0 !important;
        padding: 0 !important;
        background
    }

    html, body {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
        z-index: -5;
        background: rgba(0,0,0,0.65);
    }

    h1, h2 {
        font-family: 'Lora', sans-serif;
    }

    main {
        margin: 0 !important;
        padding: 0 !important;
    }

    

    .card-container {
        position: relative;
        display: flex;
        flex-direction: column;
        justify-content: center;
        gap: 15px;
        padding: 20px; /* ← Aggiungi padding interno */
        margin-top: 80px;
    }

    #elencoPizze{
        display: flex;
        flex-direction: column;
        gap: 10px;
        min-height: 500px;
    }

    .loading-spinner {
        text-align: center;
        padding: 40px;
        color: rgba(255, 255, 255, 0.8);
        font-size: 18px;
    }

    .cont-pizza {
        border: 1px solid #ddd;
        padding: 15px;
        border-radius: 8px;
        background: #f9f9f9;
    }

    .cont-pizza p {
        margin: 5px 0;
    }

    #searchInput {
        padding: 20px 10px;
        border-radius: 4px;
        margin: 10px 0px;
    }

    .div-tit{
        width:100%;
        display:flex;
        flex-direction: row;
        justify-content: center;
        align-items: center;
        height: 800px;
    }

    .main-title{
        color: white;
        font-size: 110px;
        text-shadow: 10px 10px 10px rgba(0,0,0,0.2);
    }

    .div-tit {
        background-image: url('/src/bg-menu.jpg');
        background-size: cover; 
        background-position: center; 
        background-repeat: no-repeat; 
        background-attachment: fixed; /* Effetto parallax */
    }

    @@media(max-width: 1600px){
        .div-tit {
            height: 80vh;
        }
    }

    .notif-overlay {
        display: none;
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        z-index: 9998;
    }

    .notif-overlay.active {
        display: block;
        background: rgba(255, 255, 255, 0.15);
    }

    .notif {
        display: none;
        top: 50%;
        left: 50%;
        transform: translateY(-50%) translateX(-50%);
        position: fixed;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        background: rgba(255,255, 255, 0.4);
        color: black;
        padding: 50px;
        box-shadow: 0 10px 40px rgba(0, 0, 0, 0.8);
        z-index: 9999;
        min-width: 300px;
    }

    .notif > h3{
        font-size: 35px;

    }

    .notif > h5 {
        font-size: 25px;
    }


    .notif.active {
        display: flex !important;
    }

    .but-continue:hover{
        cursor: pointer;
        border-bottom: 1px solid black;
    }
</style>


<div class="card-container">
    <div class="div-tit">
        <h1 class="main-title">@ViewData["Title"]</h1>
    </div>
    
    <input type="text" id="searchInput" placeholder="Find Pizzas..."/>
    <div id="elencoPizze">
        <div class="loading-spinner">
            <p>Loading pizzas...</p>
        </div>
    </div>

    <!-- Overlay scuro -->
    <div class="notif-overlay"></div>

    <!-- Notifica -->
    <div class="notif">
        <h3>Pizza Added!</h3>
        <h5 class="but-continue">Continue</h5>
    </div>
</div>

@section Scripts{
    <script src="~/js/Pizza.js"></script>
}